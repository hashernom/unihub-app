{
  "name": "unihub-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "postinstall": "node scripts/patch-ionic-core.js",
    "test": "ng test",
    "test:coverage": "ng test --coverage --watch=false",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "lighthouse": "lhci autorun",
    "k6:smoke": "k6 run k6/smoke-auth.js",
    "k6:load": "k6 run k6/load-home.js",
    "lint": "ng lint",
    "ionic:serve": "ng serve --host=0.0.0.0 --port=8100"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/pwa": "^21.2.10",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@fullcalendar/angular": "^6.1.20",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@ionic/angular": "^8.8.6",
    "@ionic/angular-toolkit": "^12.3.0",
    "@ionic/storage-angular": "^4.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "chart.js": "^4.5.1",
    "jspdf": "^4.2.1",
    "rrule": "^2.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
